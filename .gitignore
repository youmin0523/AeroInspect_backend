# =============================================
# backend/.gitignore
# 역할: Git 추적 제외 파일/폴더 목록
# =============================================

# 환경변수 (실제 키 노출 방지)
.env

# Python 가상환경
venv/
.venv/
env/

# Node 의존성 (일부 JS 툴링용 — 대용량, 실수 커밋 방지)
node_modules/

# Python 캐시
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# YOLOv8 가중치 파일 (용량 큼) — ONNX 포함 모두 제외
models_weights/*.pt
models_weights/*.pth
models_weights/*.onnx
models_weights/*.onnx.data
models_weights/*.engine
models_weights/*.bin

# 학습 산출물 (수십 GB) — GCS로 별도 관리
training/runs/
training/datasets/
training/results/
datasets/
training/eval/results/*.json
training/eval/results/*.md
training/colab/upload_to_drive/
training/colab_results_backup/
*.cache
*.npy

# 학습 로그 (큰 파일, 수십~수백 MB)
training/*.log
training/*.txt
!training/datasets_sources.md
!training/README.md

# 하자 이미지 크롭 저장 디렉토리
captured_frames/*
!captured_frames/.gitkeep

# 런타임 업로드 (프로필/평면도/채팅 첨부 등)
uploads/

# 학습 시 다운받은 모델 가중치 (yolov8m, yolo11l 등)
*.pt
yolo*.pt

# 빌드 / 배포
*.egg-info/
dist/
build/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# 테스트 커버리지
.coverage
htmlcov/
.pytest_cache/
