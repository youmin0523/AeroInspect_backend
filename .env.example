# =============================================
# backend/.env.example
# 역할: 환경변수 템플릿 (실제 .env 파일 생성 시 복사하여 사용)
# 사용법: cp .env.example .env  →  값 채우기
#
# ⚠️  배포 전 필수 점검:
#   - JWT_SECRET, AI_WEBHOOK_SECRET 은 32자 이상 무작위 값으로 교체
#   - placeholder secret 검증은 fail-closed: APP_ENV 가 dev/test 계열이 아니면
#     (production·staging·오타·미설정 포함) placeholder 값이 남아있을 때 기동 차단됨
#   - 모든 OAuth/SMTP/DB 자격증명은 시크릿 매니저(AWS Secrets Manager 등) 사용 권장
# =============================================

# ── 환경 식별 ─────────────────────────────
# 값: development | dev | local | test | testing | ci → placeholder 시크릿 경고만(통과)
#     그 외 모든 값(production/staging/오타/빈값) → placeholder 시크릿이면 기동 차단(fail-closed)
APP_ENV=development

# ── Database ───────────────────────────────
# EC2 RDS 연결 시 아래 값만 변경하면 자동으로 DATABASE_URL 조립
DB_HOST=localhost               # EC2 RDS 엔드포인트 (예: mydb.xxxx.ap-northeast-2.rds.amazonaws.com)
DB_PORT=5432                    # PostgreSQL 기본 포트
DB_USER=aeroinspect             # DB 사용자명
DB_PASSWORD=replace-me          # DB 비밀번호 (운영에서는 반드시 교체)
DB_NAME=aeroinspect_db          # 데이터베이스 이름

# ── Camera ─────────────────────────────────
RGB_CAMERA_INDEX=0          # USB Capture Card (RGB 영상) 장치 번호
THERMAL_CAMERA_INDEX=1      # IRC-256CA 열화상 카메라 장치 번호

# ── LiDAR (TF-Luna) ────────────────────────
LIDAR_SERIAL_PORT=COM3      # Windows: COM3 / Linux: /dev/ttyUSB0
LIDAR_BAUD_RATE=115200

# ── AI Model (3-모델 파이프라인) ────────────
# 가중치 디렉토리 + 개별 파일명 분리. 아래 3개 파일을 이 디렉토리에 배치:
#   - yolov8s_crack_moisture_best.pt  (YOLOv8s: Crack, Moisture)
#   - yolov8s_delamination_best.pt    (YOLOv8s: delamination)
#   - resnet50_wallpaper_best.pt      (ResNet50: 19 wallpaper classes, good=Burst 포함)
AEROINSPECT_WEIGHTS_DIR=./models_weights
YOLO_THERMAL_WEIGHTS=yolov8s_crack_moisture_best.pt
YOLO_DELAM_WEIGHTS=yolov8s_delamination_best.pt
WALLPAPER_WEIGHTS=resnet50_wallpaper_best.pt

# YOLO 공통 신뢰도 임계값 (crack_moisture + delamination)
YOLO_CONF_THRESHOLD=0.25
# ResNet50 벽지 분류 신뢰도 임계값 (val_acc 54% 감안, top1 최소 신뢰도)
WALLPAPER_CONF_THRESHOLD=0.35
# top1 - top2 최소 마진. 모호한 예측(top1/top2 근소차) 차단용
WALLPAPER_MARGIN_THRESHOLD=0.15

# WebSocket 스트림 추론: N프레임 중 1프레임만 추론
FRAME_SKIP=3

# 추론 디바이스: auto | cuda | cpu
DEVICE=auto

# 로깅 (structlog)
#   - LOG_JSON=false: 개발용 컬러 콘솔 (사람이 읽기 편함)
#   - LOG_JSON=true:  운영용 JSON 한 줄 로그 — Grafana Loki / Datadog / CloudWatch에 바로 적재
#                     (request_id, method, path 가 자동 바인딩되어 분산 추적 가능)
# 운영 배포 시: LOG_JSON=true, LOG_LEVEL=INFO (디버깅 세션 한정 DEBUG)
LOG_JSON=false
LOG_LEVEL=INFO

# ── Legacy (하위 호환 — 신규 코드에선 사용 금지) ──
YOLO_WEIGHTS_PATH=./models_weights/aeroinspect_yolov8.pt

# ── LLM API Keys ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# ── WebSocket ──────────────────────────────
WS_HEARTBEAT_INTERVAL=30    # 초 단위 핑 간격

# ── Streaming ──────────────────────────────
MJPEG_JPEG_QUALITY=80       # 0-100, 높을수록 고화질/고용량
THERMAL_BLEND_ALPHA=0.5     # 블렌드 모드 열화상 투명도 (0.0~1.0)

# ── JWT ────────────────────────────────────
# 생성 권장: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=120
JWT_REFRESH_EXPIRE_HOURS=24  # 재접속 유휴 윈도우(회전으로 갱신). 넘기면 자동 로그아웃

# ── AI Webhook (AI 추론 서버 → 백엔드 콜백 인증) ──
# /api/v1/ai/* 엔드포인트는 X-AI-Webhook-Secret 헤더가 이 값과 일치해야 통과.
# 빈 값이면 모든 요청 401. 운영에서는 32자 이상 무작위 문자열 권장.
AI_WEBHOOK_SECRET=change-me-in-production

# ── 푸시 알림 ─────────────────────────────
# noop(기본, 디버그) | fcm(Firebase Cloud Messaging) | apns(Apple Push)
PUSH_PROVIDER=noop

# ── WebSocket 백엔드 ──────────────────────
# memory(단일 워커 기본) | redis(수평 확장 시 필수)
WS_BACKEND=memory
REDIS_URL=redis://localhost:6379/0

# ── OAuth (SNS 로그인) ─────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret

NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# OAuth 콜백 redirect base (프론트 도메인). 운영 시 https 도메인으로 변경.
OAUTH_REDIRECT_BASE=http://localhost:5173

# ── Email (SMTP) ──────────────────────────
# Gmail 사용 시: smtp.gmail.com:587, "앱 비밀번호" 16자리 발급 필요.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@droneinspect.com
SMTP_FROM_NAME=DRONE INSPECT

# ── CORS ───────────────────────────────────
# JSON 배열 형식. 운영 시 프론트 도메인만 허용 (와일드카드 절대 X).
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Sentry (운영 에러 모니터링) ───────────────
# 운영 환경에서만 설정. 로컬 개발은 비워두면 자동 no-op.
# DSN 발급: sentry.io → Project → Settings → Client Keys (DSN)
# Fly 등록 예시: flyctl secrets set SENTRY_DSN="https://xxx@oXXX.ingest.sentry.io/YYY"
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# 트랜잭션 샘플링 비율 (0.0~1.0). 운영 비용 가드용 0.1 기본. 디버그 세션만 일시 1.0.
SENTRY_TRACES_SAMPLE_RATE=0.1
# 프로파일링은 비용 큼 → 기본 비활성. 필요 시 0.05~0.1.
SENTRY_PROFILES_SAMPLE_RATE=0.0

# ── Thermal Anomaly (R-v1.1.10/13) ──────────
# Moisture/delam YOLO 대체 PatchCore. 5/28 사용자 명시 보류 토글.
# True로 변경 시 models_weights/thermal_anomaly.onnx 자동 로드 (재학습 불필요).
# 영상 수신기 + thermal frame 흐름 확보 후 활성화.
THERMAL_ANOMALY_ENABLED=False

# ── Cloudflare R2 (도면/드론영상/백업 R2 스토리지) ──
# memory project_file_storage_r2 — presigned URL 방식.
# scripts/backup_pg.ps1 PostgreSQL 백업 R2 업로드에서도 사용.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=aeroinspect-files
R2_ENDPOINT_URL=
R2_PUBLIC_BASE_URL=
